# === ShiftControl Production (.env.production) ===
# Скопируй: cp .env.production.example .env.production
# setup-vps.sh создаёт этот файл автоматически

# Домен (без https://)
DOMAIN=shift.example.com

# PostgreSQL
POSTGRES_DB=shiftcontrol
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (минимум 32 символа)
JWT_SECRET=CHANGE_ME_RANDOM_32_CHARS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_RANDOM_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Yandex Maps
YANDEX_MAPS_API_KEY=

# MinIO / S3 (внутри Docker)
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
S3_BUCKET=shiftcontrol
S3_PUBLIC_URL=https://shift.example.com/files

# CORS (через запятую)
CORS_ORIGINS=https://shift.example.com

# Порты (внутри Docker, менять не нужно)
API_PORT=3001
WEB_PORT=3000

# Seed (только для первого запуска)
SUPERADMIN_EMAIL=admin@shiftcontrol.local
SUPERADMIN_PASSWORD=Admin123!@#
